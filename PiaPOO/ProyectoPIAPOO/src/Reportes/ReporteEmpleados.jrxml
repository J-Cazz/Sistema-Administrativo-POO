	<queryString>
		<![CDATA[SELECT `Id_Empleado`,
	`Nom_Empleado`,
	DATE_FORMAT( fecha_nac_emp,'%d/%b/%Y') AS fecha_nac,
	CONCAT( calle_emp,' No. ',Num_Ext_Emp) AS Calle,
	CONCAT( 'Col. ',Colonia_Emp,', ',Ciudad_Emp,', ',Estado_Emp) AS Localidad,
	CONCAT( ' C.P. ',Codigo_Postal_Emp) AS direccion,
	CONCAT( ROUND( Comision_Emp,2),'%') AS Comision,
	`CURP_Emp`,
	`RFC_Emp`,
	`Sexo_Emp`,
	DATE_FORMAT( Fecha_Contrato_Emp,'%d/%b/%Y') AS fecha_contrato,
	`Status_Emp`,
	`E_Mail_Emp`,
	`Telefono1_Emp`,
	`Telefono2_Emp`
FROM bd_inventario.empleados]]>
	</queryString>
